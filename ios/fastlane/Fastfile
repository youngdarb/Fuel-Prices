default_platform(:ios)

MATCH_GIT_URL = "https://github.com/youngdarb/ios-certificates.git"
BUNDLE_ID = "com.gsyfuelprices.ios"

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["APPSTORE_KEY_ID"],
    issuer_id: ENV["APPSTORE_ISSUER_ID"],
    key_content: ENV["APPSTORE_PRIVATE_KEY"]
  )
end

platform :ios do
  desc "One-off: revoke existing distribution certs (frees Apple's cert quota)"
  lane :nuke do
    asc_api_key
    match_nuke(
      type: "appstore",
      git_url: MATCH_GIT_URL,
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"],
      skip_confirmation: true
    )
  end

  desc "Build signed IPA and upload to TestFlight/App Store Connect"
  lane :release do
    api_key = asc_api_key

    create_keychain(
      name: "ci",
      password: "ci_password",
      default_keychain: true,
      unlock: true,
      timeout: 3600
    )

    # Certificates + profile from the encrypted private repo,
    # created there once and reused on every run
    match(
      type: "appstore",
      app_identifier: BUNDLE_ID,
      git_url: MATCH_GIT_URL,
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"],
      keychain_name: "ci",
      keychain_password: "ci_password",
      readonly: false
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "pwa-shell.xcodeproj",
      team_id: ENV["APPLE_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING][BUNDLE_ID],
      targets: ["pwa-shell"]
    )

    build_app(
      workspace: "pwa-shell.xcworkspace",
      scheme: "pwa-shell",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "GSYFuel.ipa"
    )

    # NOTE: the App Store Connect app record cannot be created via API —
    # it must exist already (My Apps → + → New App, bundle id com.gsyfuelprices.ios)
    upload_to_testflight(
      api_key: api_key,
      ipa: "build/GSYFuel.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end
